# 本文件是本地开发 .env 与 Docker 部署 env 的统一变量契约。
# 两边使用同一批 key、同一含义、同一必填性；不同环境只改 value。
# 本地开发地址通常使用 127.0.0.1 和宿主机映射端口。
# Docker 部署地址通常使用 Compose 服务名和容器内部端口：
#   ADMIN_API_POSTGRES_URL=postgresql://postgres:<password>@postgres:5432/yzj_ai_crm
#   SKILL_RUNTIME_POSTGRES_URL=postgresql://postgres:<password>@postgres:5432/yzj_ai_crm
#   MONGODB_URI=mongodb://mongodb:27017
#   QDRANT_URL=http://qdrant:6333
#   SKILL_RUNTIME_BASE_URL=http://skill-runtime:3012
#   TONGYI_AUDIO_SERVICE_BASE_URL=http://tongyi-audio-service:3018

YZJ_EID=your_eid
YZJ_APP_ID=your_app_id
YZJ_APP_SECRET=your_app_secret
YZJ_SIGN_KEY=your_sign_key
YZJ_ORG_READ_SECRET=your_org_read_secret
YZJ_APPROVAL_APP_ID=your_approval_app_id
YZJ_APPROVAL_APP_SECRET=your_approval_app_secret
YZJ_APPROVAL_DEV_KEY=your_approval_dev_key
YZJ_APPROVAL_FILE_SECRET=your_approval_file_secret
YZJ_LIGHTCLOUD_APP_ID=your_lightcloud_app_id
YZJ_LIGHTCLOUD_APP_SECRET=your_lightcloud_app_secret
YZJ_LIGHTCLOUD_SECRET=your_lightcloud_secret
YZJ_SHADOW_CUSTOMER_FORM_CODE_ID=your_customer_form_code_id
YZJ_SHADOW_CONTACT_FORM_CODE_ID=your_contact_form_code_id
YZJ_SHADOW_OPPORTUNITY_FORM_CODE_ID=your_opportunity_form_code_id
YZJ_SHADOW_FOLLOWUP_FORM_CODE_ID=your_followup_form_code_id
YZJ_SHADOW_DICTIONARY_SOURCE=manual_json
YZJ_SHADOW_DICTIONARY_JSON_PATH=.local/shadow-dictionaries.json
YZJ_SHADOW_SKILL_OUTPUT_DIR=skills/shadow
EXT_IMAGE_BASE_URL=https://api.linkapi.org
EXT_IMAGE_API_KEY=your_image_api_key
EXT_IMAGE_MODEL=gpt-image-2
EXT_IMAGE_TIMEOUT_MS=150000
SKILL_RUNTIME_BASE_URL=http://127.0.0.1:3012
TONGYI_AUDIO_SERVICE_BASE_URL=http://127.0.0.1:3018
TONGYI_AUDIO_SERVICE_PORT=3018
TONGYI_DASHSCOPE_API_KEY=
TONGYI_TINGWU_APP_ID=
TONGYI_AUDIO_OUTPUT_DIR=tmp/tongyi
TONGYI_AUDIO_FIXTURE_OUTPUT_DIR=tmp/tongyi
ADMIN_API_PORT=3001
SUPER_PPT_EDITOR_PORT=8001
SUPER_PPT_EDITOR_BASE_URL=http://127.0.0.1:8001
ORG_SYNC_SQLITE_PATH=.local/admin-api.sqlite
ADMIN_API_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/yzj_ai_crm_dev
ADMIN_API_POSTGRES_SCHEMA=admin_api
MONGODB_URI=mongodb://127.0.0.1:27018
MONGODB_DB=yzj_ai_crm_dev
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=yzj_artifact_chunks
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
SKILL_RUNTIME_PORT=3012
SKILL_RUNTIME_SQLITE_PATH=.local/skill-runtime.sqlite
SKILL_RUNTIME_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/yzj_ai_crm_dev
SKILL_RUNTIME_POSTGRES_SCHEMA=skill_runtime
SKILL_RUNTIME_ARTIFACT_DIR=.local/skill-runtime-artifacts
SKILL_RUNTIME_ALLOWED_ROOTS=.
SKILL_RUNTIME_SKILL_DIRS=3rdSkill
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=your_ark_api_key
ARK_WEB_SEARCH_MODEL=doubao-seed-2-0-lite-260215
DOCMEE_BASE_URL=https://open.docmee.cn
DOCMEE_API_KEY=your_docmee_api_key
DOCMEE_EDITOR_TOKEN_HOURS=1
